generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USERS
// ============================================
enum UserRole {
  admin
  field_user
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(field_user)
  phone        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  routePlans    WeeklyRoutePlan[]
  visits        Visit[]
  activityLogs  ActivityLog[]
  importBatches ProspectImportBatch[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ============================================
// PROSPECTS
// ============================================
enum ProspectStatus {
  active
  passive
  visited
}

model Prospect {
  id            String         @id @default(uuid())
  companyName   String         @map("company_name")
  contactPerson String         @map("contact_person")
  phone         String
  email         String?
  address       String
  latitude      Decimal        @db.Decimal(10, 7)
  longitude     Decimal        @db.Decimal(10, 7)
  sector        String?
  notes         String?
  status        ProspectStatus @default(active)
  importBatchId String?        @map("import_batch_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Relations
  importBatch    ProspectImportBatch? @relation(fields: [importBatchId], references: [id])
  routePlanItems RoutePlanItem[]
  visits         Visit[]

  @@unique([companyName, phone], name: "prospect_company_phone")
  @@index([status])
  @@map("prospects")
}

// ============================================
// IMPORT BATCHES
// ============================================
enum ImportBatchStatus {
  processing
  completed
  failed
}

model ProspectImportBatch {
  id             String            @id @default(uuid())
  fileName       String            @map("file_name")
  uploadedBy     String            @map("uploaded_by")
  totalRows      Int               @map("total_rows")
  successCount   Int               @default(0) @map("success_count")
  errorCount     Int               @default(0) @map("error_count")
  duplicateCount Int               @default(0) @map("duplicate_count")
  status         ImportBatchStatus @default(processing)
  errorDetails   Json?             @map("error_details")
  createdAt      DateTime          @default(now()) @map("created_at")

  // Relations
  uploader  User       @relation(fields: [uploadedBy], references: [id])
  prospects Prospect[]

  @@map("prospect_import_batches")
}

// ============================================
// WEEKLY ROUTE PLANS
// ============================================
enum RoutePlanStatus {
  draft
  active
  completed
}

model WeeklyRoutePlan {
  id         String          @id @default(uuid())
  userId     String          @map("user_id")
  year       Int
  weekNumber Int             @map("week_number")
  status     RoutePlanStatus @default(draft)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")

  // Relations
  user  User            @relation(fields: [userId], references: [id])
  items RoutePlanItem[]

  @@unique([userId, year, weekNumber], name: "plan_user_year_week")
  @@map("weekly_route_plans")
}

enum RoutePlanItemStatus {
  pending
  visited
  skipped
}

model RoutePlanItem {
  id          String              @id @default(uuid())
  planId      String              @map("plan_id")
  prospectId  String              @map("prospect_id")
  visitOrder  Int                 @map("visit_order")
  plannedDate DateTime?           @map("planned_date") @db.Date
  status      RoutePlanItemStatus @default(pending)
  createdAt   DateTime            @default(now()) @map("created_at")

  // Relations
  plan     WeeklyRoutePlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  prospect Prospect        @relation(fields: [prospectId], references: [id])
  visits   Visit[]

  @@unique([planId, prospectId], name: "plan_item_unique")
  @@map("route_plan_items")
}

// ============================================
// VISITS
// ============================================
enum VisitResult {
  positive
  neutral
  negative
}

enum VisitStatus {
  started
  completed
  cancelled
}

model Visit {
  id               String       @id @default(uuid())
  userId           String       @map("user_id")
  prospectId       String       @map("prospect_id")
  routePlanItemId  String?      @map("route_plan_item_id")
  startTime        DateTime     @map("start_time")
  endTime          DateTime?    @map("end_time")
  startLatitude    Decimal      @map("start_latitude") @db.Decimal(10, 7)
  startLongitude   Decimal      @map("start_longitude") @db.Decimal(10, 7)
  endLatitude      Decimal?     @map("end_latitude") @db.Decimal(10, 7)
  endLongitude     Decimal?     @map("end_longitude") @db.Decimal(10, 7)
  result           VisitResult?
  resultNotes      String?      @map("result_notes")
  status           VisitStatus  @default(started)
  cancelReason     String?      @map("cancel_reason")
  durationMinutes  Int?         @map("duration_minutes")
  createdAt        DateTime     @default(now()) @map("created_at")

  // Relations
  user          User           @relation(fields: [userId], references: [id])
  prospect      Prospect       @relation(fields: [prospectId], references: [id])
  routePlanItem RoutePlanItem? @relation(fields: [routePlanItemId], references: [id])

  @@index([userId, status])
  @@index([prospectId])
  @@index([createdAt])
  @@map("visits")
}

// ============================================
// ACTIVITY LOGS
// ============================================
model ActivityLog {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  // Relations
  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

// ============================================
// EMAIL DISPATCH LOGS
// ============================================
enum EmailDispatchStatus {
  sent
  failed
  retrying
}

model EmailDispatchLog {
  id             String              @id @default(uuid())
  dispatchDate   DateTime            @map("dispatch_date") @db.Date
  recipientEmail String              @map("recipient_email")
  subject        String
  contentSummary Json                @map("content_summary")
  status         EmailDispatchStatus @default(retrying)
  retryCount     Int                 @default(0) @map("retry_count")
  errorMessage   String?             @map("error_message")
  sentAt         DateTime?           @map("sent_at")
  createdAt      DateTime            @default(now()) @map("created_at")

  @@index([dispatchDate])
  @@index([status])
  @@map("email_dispatch_logs")
}

// ============================================
// APP SETTINGS
// ============================================
model AppSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}
